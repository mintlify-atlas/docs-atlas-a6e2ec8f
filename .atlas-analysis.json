  "keyFeatures": [
    "GitHub OAuth authentication with NextAuth",
    "Multiple analysis modes (blame, commits, GitHub API, hybrid)",
    "Real-time streaming analysis with SSE progress updates",
    "AI-powered manager reports using OpenAI",
    "Rich visualizations (timelines, heatmaps, Gantt charts)",
    "CSV/text exports for contributors and commit data",
    "Rate limit handling and caching",
    "Repository and branch browsing"
  ],
  "publicApiSurface": [
    "GET /api/github/repos - List user repositories",
    "GET /api/github/branches - List repository branches",
    "POST /api/github/analyze - Analyze contributions",
    "GET /api/github/analyze/stream - Stream analysis progress",
    "POST /api/github/analyze/advanced - Advanced analysis",
    "GET /api/github/analyze/advanced/stream - Stream advanced analysis",
    "POST /api/ai/manager-report - Generate AI manager report"
  ]
}
