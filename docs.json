{
  "$schema": "https://mintlify.com/docs.json",
  "name": "gitDash",
  "theme": "palm",
  "colors": {
    "primary": "#0969DA",
    "light": "#54AEFF",
    "dark": "#0550AE"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/Krut-in/gitDash"
    }
  },
  "footer": {
